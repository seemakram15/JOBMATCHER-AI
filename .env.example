SERPAPI_KEY=dummy-serpapi-key

# New added keys
ADZUNA_APP_ID=dummy-adzuna-app-id
ADZUNA_APP_KEY=dummy-adzuna-app-key
ADZUNA_APP_KEYS=dummy-adzuna-key-1,dummy-adzuna-key-2
