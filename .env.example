# Supabase database, auth, and storage.
# DATABASE_URL: server-side Postgres fallback for confirmed signup and maintenance tasks.
DATABASE_URL=postgresql://postgres.project:dummy-password@aws-1-region.pooler.supabase.com:6543/postgres
# DB_PASSWORD: password portion of the Supabase pooled database URL, kept separate for operators.
DB_PASSWORD=dummy-db-password
# SUPABASE_URL: server-side Supabase project URL for admin/API routes.
SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_PUBLISHABLE_KEY: server-side publishable key when a server route needs public Supabase access.
SUPABASE_PUBLISHABLE_KEY=sb_publishable_dummy
# VITE_SUPABASE_URL: browser Supabase project URL for client auth and user-owned data.
VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_PUBLISHABLE_KEY: browser-safe Supabase publishable key.
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_dummy
# SUPABASE_SERVICE_ROLE_KEY: server-only admin key for no-email signup and recovery-token generation.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_dummy_service_role_key
# SUPABASE_ACCESS_TOKEN: local/operator-only Supabase management token for CLI/dashboard automation.
SUPABASE_ACCESS_TOKEN=dummy-supabase-access-token

# AI.
# ANTHROPIC_API_KEY: optional future AI enhancement; CV parsing currently runs locally without it.
ANTHROPIC_API_KEY=dummy-anthropic-key

# Job scraping and live job discovery.
# APIFY_API_TOKEN: primary Apify token for actors/scrapers.
APIFY_API_TOKEN=apify_api_dummy
# APIFY_API_KEYS: fallback Apify tokens used when one account runs out of credits.
APIFY_API_KEYS=apify_api_dummy_1,apify_api_dummy_2
# APIFY_WEBHOOK_SECRET: verifies inbound Apify webhook calls.
APIFY_WEBHOOK_SECRET=dummy-webhook-secret
# SERPAPI_KEY: Google Jobs source through SerpApi.
SERPAPI_KEY=dummy-serpapi-key

# ADZUNA_APP_ID / ADZUNA_APP_KEY: Adzuna job source credentials.
ADZUNA_APP_ID=dummy-adzuna-app-id
ADZUNA_APP_KEY=dummy-adzuna-app-key
# ADZUNA_APP_KEYS: optional fallback Adzuna keys.
ADZUNA_APP_KEYS=dummy-adzuna-key-1,dummy-adzuna-key-2
# JOOBLE_API_KEY / JOOBLE_API_KEYS: Jooble job source primary and fallback keys.
JOOBLE_API_KEY=dummy-jooble-key
JOOBLE_API_KEYS=dummy-jooble-key-1,dummy-jooble-key-2
# RAPIDAPI_KEY: RapidAPI JSearch job source key.
RAPIDAPI_KEY=dummy-rapidapi-key
# OPENWEB_NINJA_API_KEY: OpenWeb Ninja job search source key.
OPENWEB_NINJA_API_KEY=dummy-openweb-ninja-key

# Email.
# BREVO_API_KEY: Brevo REST v3 API key for custom transactional password-reset emails.
BREVO_API_KEY=xkeysib_dummy
# BREVO_SENDER_EMAIL: verified Brevo sender email.
BREVO_SENDER_EMAIL=noreply@example.com
# BREVO_SENDER_NAME: sender display name shown in inboxes.
BREVO_SENDER_NAME=Jobmatcher

# Cache and rate limiting.
# UPSTASH_REDIS_REST_URL: shared Redis REST endpoint for production cache/rate limits.
UPSTASH_REDIS_REST_URL=https://dummy-upstash-url.upstash.io
# UPSTASH_REDIS_REST_TOKEN: shared Redis REST token.
UPSTASH_REDIS_REST_TOKEN=dummy-upstash-token
# UPSTASH_REDIS_DATABASE_ID: Upstash database identifier for ops visibility.
UPSTASH_REDIS_DATABASE_ID=dummy-upstash-database-id

# OAuth.
# GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET: Google OAuth provider credentials.
GOOGLE_CLIENT_ID=dummy-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=dummy-google-client-secret
# GITHUB_CLIENT_ID / GITHUB_CLIENT_SECRET: GitHub OAuth provider credentials.
GITHUB_CLIENT_ID=dummy-github-client-id
GITHUB_CLIENT_SECRET=dummy-github-client-secret

# Deployment and repository operations.
# VERCEL_TOKEN: deploy/env-management token for Vercel CLI.
VERCEL_TOKEN=dummy-vercel-token
# GITHUB_REMOTE_URL: canonical repository remote.
GITHUB_REMOTE_URL=https://github.com/your-org/jobmatcher.git
# SENDER_EMAIL: legacy/fallback sender value; Brevo-specific sender is preferred.
SENDER_EMAIL=jobs@example.com

# App URLs.
# APP_URL: server-side canonical URL; production must be https://myjobmatcher.vercel.app.
APP_URL=https://myjobmatcher.vercel.app
# VITE_APP_URL: browser/build canonical URL; production must be https://myjobmatcher.vercel.app.
VITE_APP_URL=https://myjobmatcher.vercel.app
# NODE_ENV: runtime mode.
NODE_ENV=development
